{
  "name": "@grapit/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*",
      "default": "./dist/schemas/*"
    },
    "./types/*": {
      "types": "./dist/types/*",
      "default": "./dist/types/*"
    },
    "./constants/*": {
      "types": "./dist/constants/*",
      "default": "./dist/constants/*"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "~5.9.0"
  }
}
