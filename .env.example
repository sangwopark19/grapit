# Database
DATABASE_URL=postgresql://grapit:grapit_dev@localhost:5432/grapit

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# OAuth - Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:8080/api/v1/auth/social/kakao/callback

# OAuth - Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:8080/api/v1/auth/social/naver/callback

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/social/google/callback

# Toss Payments (public doc test keys -- safe to use as-is for development)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY=test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6

# -- Toss Payments (E2E test-only -- CI-only keys, NEVER in deploy.yml) --
# Public docs test keys from Toss documentation (https://docs.tosspayments.com);
# safe to commit -- no real funds move. Used exclusively by Playwright E2E to prove
# we can reach Toss sandbox from CI without mixing test keys into production env.
# Key isolation rationale: 09-CONTEXT.md D-13.
TOSS_CLIENT_KEY_TEST=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY_TEST=test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6

# -- Playwright E2E test user (Blocker B2) --
# Local: falls back to seed credentials (admin@grapit.test / TestAdmin2026! from
# apps/api/src/database/seed.mjs:39-50). Set these only if your seed differs.
# CI: set as GitHub secrets (TEST_USER_EMAIL / TEST_USER_PASSWORD) when the CI DB
# seeds different credentials.
# TEST_USER_EMAIL=admin@grapit.test
# TEST_USER_PASSWORD=TestAdmin2026!

# Twilio (SMS) - optional, dev mock mode if absent
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Redis - optional, defaults used if absent
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=redis://localhost:6379

# -- Email (Resend) --
# Required in production. Dev environment without these values falls back to console.log mock.
# Production: both RESEND_API_KEY and RESEND_FROM_EMAIL are hard-required (see EmailService constructor).
# RESEND_FROM_EMAIL must be a verified sender domain configured in Resend dashboard.
# RESEND_API_KEY=re_your_api_key_here
# RESEND_FROM_EMAIL=no-reply@grapit.com

# App
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=http://localhost:8080
NODE_ENV=development

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
